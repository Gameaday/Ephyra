<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Include files that should be backed up to the cloud -->
        <include domain="root" />
    </cloud-backup>
    <device-transfer>
        <!-- Include files that should be transferred to a new device -->
        <include domain="root" />
    </device-transfer>
</data-extraction-rules>
